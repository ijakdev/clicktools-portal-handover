"use client";

import React, { useEffect, useState, useRef } from 'react';
import Link from 'next/link';
import { 
    Plus, Search, Edit2, Trash2, ExternalLink, 
    X, Check, Loader2, Image as ImageIcon, 
    Eye, Layout, MousePointer2, Calendar, User
} from 'lucide-react';
import { toast } from 'sonner';
import { cn } from '@/lib/utils';

interface BlogPost {
    id: number;
    slug: string;
    title: string;
    excerpt: string;
    category: string;
    thumbnail: string;
    content: string;
    created_at: string;
}

export default function AdminBlogPage() {
    const [posts, setPosts] = useState<BlogPost[]>([]);
    const [isLoading, setIsLoading] = useState(true);
    const [isMenuOpen, setIsMenuOpen] = useState(false);
    const [editingPost, setEditingPost] = useState<Partial<BlogPost> | null>(null);
    const [isSaving, setIsSaving] = useState(false);
    const [viewMode, setViewMode] = useState<'split' | 'edit' | 'preview'>('split');
    const [isUploading, setIsUploading] = useState(false);
    const fileInputRef = useRef<HTMLInputElement>(null);

    useEffect(() => {
        fetchPosts();
    }, []);

    const fetchPosts = async () => {
        setIsLoading(true);
        try {
            const res = await fetch('/api/admin/blog');
            const data = await res.json();
            setPosts(Array.isArray(data) ? data : []);
        } catch (e) {
            toast.error('포스트를 불러오지 못했습니다.');
        } finally {
            setIsLoading(false);
        }
    };

    const handleSave = async (e: React.FormEvent) => {
        e.preventDefault();
        setIsSaving(true);

        const method = editingPost?.id ? 'PUT' : 'POST';
        
        try {
            const res = await fetch('/api/admin/blog', {
                method,
                body: JSON.stringify(editingPost),
                headers: { 'Content-Type': 'application/json' }
            });

            const data = await res.json();

            if (res.ok) {
                toast.success(editingPost?.id ? '성공적으로 수정되었습니다.' : '성공적으로 등록되었습니다.');
                closeEditor();
                fetchPosts();
            } else {
                toast.error(data.error || '저장에 실패했습니다.');
            }
        } catch (error) {
            toast.error('서버 오류가 발생했습니다.');
        } finally {
            setIsSaving(false);
        }
    };

    const handleDelete = async (id: number) => {
        if (!confirm('정말 삭제하시겠습니까?')) return;

        try {
            const res = await fetch(`/api/admin/blog?id=${id}`, { method: 'DELETE' });
            if (res.ok) {
                toast.success('게시물이 삭제되었습니다.');
                fetchPosts();
            } else {
                toast.error('삭제에 실패했습니다.');
            }
        } catch (error) {
            toast.error('서버 오류가 발생했습니다.');
        }
    };

    const openEditor = (post: BlogPost | null = null) => {
        if (post) {
            setEditingPost(post);
        } else {
            setEditingPost({
                slug: '',
                title: '',
                excerpt: '',
                category: '가이드',
                thumbnail: 'https://images.unsplash.com/photo-1542744173-8e7e53415bb0?q=80&w=400&auto=format&fit=crop',
                content: ''
            });
        }
        setIsMenuOpen(true);
        document.body.style.overflow = 'hidden';
    };

    const closeEditor = () => {
        setIsMenuOpen(false);
        setEditingPost(null);
        document.body.style.overflow = 'auto';
    };

    const handleImageUpload = async (e: React.ChangeEvent<HTMLInputElement>) => {
        const file = e.target.files?.[0];
        if (!file) return;

        setIsUploading(true);
        const formData = new FormData();
        formData.append('file', file);

        try {
            const res = await fetch('/api/admin/upload', {
                method: 'POST',
                body: formData
            });

            const data = await res.json();

            if (res.ok) {
                setEditingPost(prev => prev ? { ...prev, thumbnail: data.url } : null);
                toast.success('이미지가 업로드되었습니다.');
            } else {
                toast.error(data.error || '업로드에 실패했습니다.');
            }
        } catch (error) {
            toast.error('서버 오류가 발생했습니다.');
        } finally {
            setIsUploading(false);
            if (fileInputRef.current) fileInputRef.current.value = '';
        }
    };

    const formatContent = (content: string) => {
        if (!content) return '';
        return content
            // Support for horizontal rules: 3 or more ---, ***, ___ (with potential spaces)
            .replace(/^\s*([-*_])(?:\s*\1){2,}\s*$/gm, '<hr class="my-10 border-t-2 border-slate-200" />')
            // Bold text: **text**
            .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
    };

    return (
        <div className="space-y-6">
            <div className="flex justify-between items-center">
                <div className="relative group w-96">
                    <Search className="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400 group-focus-within:text-indigo-500 transition-colors" />
                    <input 
                        type="text" 
                        placeholder="제목 또는 슬러그 검색..." 
                        className="w-full bg-white border border-slate-200 p-3 pl-12 rounded-sm text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500/10 shadow-sm"
                    />
                </div>
                <button 
                    onClick={() => openEditor()}
                    className="bg-indigo-600 text-white px-8 py-3 rounded-none font-black uppercase tracking-widest text-[10px] flex items-center gap-2 hover:bg-indigo-500 transition-all shadow-xl shadow-indigo-900/10 active:scale-95 border border-indigo-500"
                >
                    <Plus className="w-4 h-4" />
                    새 게시물 작성
                </button>
            </div>

            {/* Posts Table */}
            <div className="bg-white border border-slate-200 shadow-xl overflow-hidden">
                <table className="w-full text-left">
                    <thead className="bg-slate-50 border-b border-slate-200">
                        <tr>
                            <th className="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-slate-500">미디어</th>
                            <th className="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-slate-500">제목 / 슬러그</th>
                            <th className="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-slate-500">카테고리</th>
                            <th className="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-slate-500 text-right">관리</th>
                        </tr>
                    </thead>
                    <tbody className="divide-y divide-slate-100">
                        {isLoading ? (
                             <tr>
                                <td colSpan={4} className="p-20 text-center">
                                    <Loader2 className="w-8 h-8 animate-spin mx-auto text-indigo-500 opacity-20" />
                                </td>
                             </tr>
                        ) : posts.length === 0 ? (
                            <tr>
                                <td colSpan={4} className="p-20 text-center text-slate-400 font-bold uppercase tracking-widest text-[10px] italic">등록된 데이터가 없습니다</td>
                            </tr>
                        ) : (
                            posts.map((post) => (
                                <tr key={post.id} className="hover:bg-slate-50 transition-colors group">
                                    <td className="px-8 py-6">
                                        <div className="w-24 aspect-[1.5] border border-slate-200 shadow-sm overflow-hidden">
                                            <img src={post.thumbnail} alt="" className="w-full h-full object-cover filter grayscale group-hover:grayscale-0 transition-all duration-500" />
                                        </div>
                                    </td>
                                    <td className="px-8 py-6">
                                        <div className="flex flex-col">
                                            <span className="text-sm font-black text-slate-900 mb-1 leading-tight">{post.title}</span>
                                            <span className="text-[10px] font-bold text-slate-400 uppercase tracking-tight">/{post.slug}</span>
                                        </div>
                                    </td>
                                    <td className="px-8 py-6">
                                        <span className="px-2 py-0.5 bg-indigo-50 text-indigo-600 text-[10px] font-black uppercase tracking-widest border border-indigo-100">
                                            {post.category}
                                        </span>
                                    </td>
                                    <td className="px-8 py-6 text-right">
                                        <div className="flex justify-end gap-1">
                                            <button 
                                                onClick={() => openEditor(post)}
                                                className="p-3 bg-white text-slate-500 border border-slate-200 hover:bg-slate-900 hover:text-white transition-all shadow-sm"
                                            >
                                                <Edit2 className="w-4 h-4" />
                                            </button>
                                            <button 
                                                onClick={() => handleDelete(post.id)}
                                                className="p-3 bg-white text-slate-500 border border-slate-200 hover:bg-red-600 hover:text-white transition-all shadow-sm"
                                            >
                                                <Trash2 className="w-4 h-4" />
                                            </button>
                                            <Link 
                                                href={`/blog/${post.slug}`} 
                                                target="_blank"
                                                className="p-3 bg-white text-slate-500 border border-slate-200 hover:bg-indigo-600 hover:text-white transition-all shadow-sm"
                                            >
                                                <ExternalLink className="w-4 h-4" />
                                            </Link>
                                        </div>
                                    </td>
                                </tr>
                            ))
                        )}
                    </tbody>
                </table>
            </div>

            {/* Premium Full-Screen Editor Overlay */}
            {isMenuOpen && (
                <div className="fixed inset-0 z-[9999] bg-white flex flex-col md:flex-row animate-in fade-in duration-300">
                    {/* Header Bar */}
                    <div className="absolute top-0 inset-x-0 h-16 bg-slate-900 flex justify-between items-center px-6 z-[100] border-b border-slate-800">
                        <div className="flex items-center gap-6">
                            <h3 className="text-white font-black tracking-[0.3em] uppercase text-[10px] italic flex items-center gap-2">
                                <Layout className="w-4 h-4 text-indigo-500" />
                                콘텐츠 엔진 시스템 v1.0
                            </h3>
                            <div className="hidden md:flex bg-white/5 p-1 border border-white/10">
                                <button 
                                    onClick={() => setViewMode('edit')}
                                    className={cn("px-6 py-1.5 text-[10px] font-black uppercase tracking-widest transition-all", viewMode === 'edit' ? "bg-indigo-500 text-white" : "text-white/40 hover:text-white")}
                                >
                                    편집기
                                </button>
                                <button 
                                    onClick={() => setViewMode('split')}
                                    className={cn("px-6 py-1.5 text-[10px] font-black uppercase tracking-widest transition-all", viewMode === 'split' ? "bg-indigo-500 text-white" : "text-white/40 hover:text-white")}
                                >
                                    분할 화면
                                </button>
                                <button 
                                    onClick={() => setViewMode('preview')}
                                    className={cn("px-6 py-1.5 text-[10px] font-black uppercase tracking-widest transition-all", viewMode === 'preview' ? "bg-indigo-500 text-white" : "text-white/40 hover:text-white")}
                                >
                                    전체 미리보기
                                </button>
                            </div>
                        </div>
                        <div className="flex items-center gap-2">
                            <button 
                                onClick={closeEditor} 
                                className="px-6 py-2 bg-white/5 text-white border border-white/10 text-[10px] font-black uppercase tracking-widest hover:bg-red-600 hover:border-red-500 transition-all font-bold"
                            >
                                <X className="w-4 h-4 inline-block mr-1" /> 나가기
                            </button>
                            <button 
                                form="editor-full-form"
                                type="submit"
                                disabled={isSaving}
                                className="px-10 py-2 bg-indigo-500 text-white border border-indigo-400 text-[10px] font-black uppercase tracking-widest hover:bg-indigo-400 transition-all shadow-xl shadow-indigo-900/40 flex items-center gap-2"
                            >
                                {isSaving ? <Loader2 className="w-4 h-4 animate-spin" /> : <Check className="w-4 h-4" />}
                                지금 게시하기
                            </button>
                        </div>
                    </div>

                    {/* Editor Pane (Left/Center) */}
                    <div className={cn(
                        "flex-grow h-full pt-16 flex flex-col transition-all duration-500",
                        viewMode === 'preview' ? "w-0 overflow-hidden opacity-0" : "w-full md:w-1/2 opacity-100",
                        viewMode === 'edit' && "md:w-full"
                    )}>
                        <div className="flex-grow overflow-y-auto p-8 md:p-12 bg-slate-50 shadow-inner">
                            <form id="editor-full-form" onSubmit={handleSave} className="max-w-4xl mx-auto space-y-12 pb-32">
                                <div className="space-y-8">
                                    <div className="border-b-2 border-slate-900 pb-2 mb-8">
                                        <input 
                                            type="text" 
                                            value={editingPost?.title || ''}
                                            onChange={e => setEditingPost({...editingPost, title: e.target.value})}
                                            className="w-full bg-transparent border-none text-3xl font-black text-slate-900 placeholder:text-slate-200 focus:outline-none tracking-tight uppercase"
                                            placeholder="제목 없는 게시물"
                                            required
                                        />
                                    </div>
                                    
                                    <div className="grid grid-cols-1 md:grid-cols-3 gap-6 pt-6 border-t border-slate-200">
                                        <div className="space-y-2">
                                            <label className="text-[10px] font-black text-slate-400 uppercase tracking-[0.3em]">URL 슬러그</label>
                                            <input 
                                                type="text" 
                                                value={editingPost?.slug || ''}
                                                onChange={e => setEditingPost({...editingPost, slug: e.target.value})}
                                                className="w-full bg-white border border-slate-200 p-4 rounded-none text-xs font-bold focus:outline-none focus:border-indigo-500"
                                                placeholder="slug-path"
                                                required
                                            />
                                        </div>
                                        <div className="space-y-2">
                                            <label className="text-[10px] font-black text-slate-400 uppercase tracking-[0.3em]">카테고리 분류</label>
                                            <select 
                                                value={editingPost?.category || '가이드'}
                                                onChange={e => setEditingPost({...editingPost, category: e.target.value})}
                                                className="w-full bg-white border border-slate-200 p-4 rounded-none text-xs font-bold focus:outline-none focus:border-indigo-500 appearance-none"
                                            >
                                                <option value="가이드">가이드</option>
                                                <option value="업무 팁">업무 팁</option>
                                                <option value="마케팅">마케팅</option>
                                                <option value="공지사항">공지사항</option>
                                            </select>
                                        </div>
                                        <div className="space-y-2">
                                            <label className="text-[10px] font-black text-slate-400 uppercase tracking-[0.3em]">대표 이미지 (썸네일)</label>
                                            <div className="flex gap-2">
                                                <div className="relative flex-grow">
                                                    <ImageIcon className="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400" />
                                                    <input 
                                                        type="text" 
                                                        value={editingPost?.thumbnail || ''}
                                                        onChange={e => setEditingPost({...editingPost, thumbnail: e.target.value})}
                                                        className="w-full bg-white border border-slate-200 p-4 pl-12 rounded-none text-[10px] font-bold focus:outline-none focus:border-indigo-500"
                                                        placeholder="https://..."
                                                        required
                                                    />
                                                </div>
                                                <button 
                                                    type="button"
                                                    onClick={() => fileInputRef.current?.click()}
                                                    disabled={isUploading}
                                                    className="px-4 bg-slate-900 text-white text-[9px] font-bold uppercase tracking-widest hover:bg-slate-800 transition-all flex items-center gap-2 border border-slate-800"
                                                >
                                                    {isUploading ? <Loader2 className="w-3 h-3 animate-spin" /> : <Search className="w-3 h-3" />}
                                                    찾기
                                                </button>
                                                <input 
                                                    type="file" 
                                                    ref={fileInputRef} 
                                                    onChange={handleImageUpload} 
                                                    className="hidden" 
                                                    accept="image/*"
                                                />
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div className="space-y-2">
                                        <label className="text-[10px] font-black text-slate-400 uppercase tracking-[0.3em]">요약 설명</label>
                                        <textarea 
                                            rows={2}
                                            value={editingPost?.excerpt || ''}
                                            onChange={e => setEditingPost({...editingPost, excerpt: e.target.value})}
                                            className="w-full bg-white border border-slate-200 p-4 rounded-none text-xs font-bold leading-relaxed focus:outline-none focus:border-indigo-500"
                                            placeholder="게시물의 주요 내용을 요약해주세요..."
                                            required
                                        />
                                    </div>

                                    <div className="space-y-2">
                                        <label className="text-[10px] font-black text-slate-400 uppercase tracking-[0.3em] flex justify-between">
                                            본문 내용 (HTML 엔진)
                                            <span className="text-indigo-600 bg-indigo-50 px-2 py-0.5 tracking-normal font-bold">상태: HTML 파싱 활성화</span>
                                        </label>
                                        <textarea 
                                            value={editingPost?.content || ''}
                                            onChange={e => setEditingPost({...editingPost, content: e.target.value})}
                                            className="w-full bg-slate-950 text-indigo-400/80 p-10 rounded-none text-base font-mono leading-relaxed focus:outline-none shadow-2xl min-h-[600px] border border-slate-800"
                                            placeholder="여기에 본문 내용을 작성하십시오..."
                                            required
                                        />
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>

                    {/* Preview Pane (Right/Center) */}
                    <div className={cn(
                        "flex-grow h-full pt-16 bg-white border-l border-slate-200 transition-all duration-500",
                        viewMode === 'edit' ? "w-0 overflow-hidden opacity-0" : "w-full md:w-1/2 opacity-100",
                        viewMode === 'preview' && "md:w-full border-none"
                    )}>
                        <div className="h-full overflow-y-auto px-8 md:px-16 py-16 pb-40">
                             <div className="max-w-3xl mx-auto">
                                {/* Preview Header */}
                                <div className="mb-10 text-center md:text-left border-b-2 border-slate-100 pb-8">
                                    <span className="px-2 py-0.5 bg-slate-900 text-white text-[9px] font-black uppercase tracking-[0.3em] mb-4 inline-block">
                                        {editingPost?.category}
                                    </span>
                                    <h1 className="text-4xl md:text-5xl font-black mb-6 leading-tight text-slate-900 tracking-tighter">
                                        {editingPost?.title || '게시물 제목 미리보기'}
                                    </h1>
                                    <div className="flex items-center justify-center md:justify-start gap-6 text-[10px] font-black text-slate-400 uppercase tracking-widest">
                                        <div className="flex items-center gap-2"><Calendar size={14} className="text-indigo-500" /> 2026-04-09</div>
                                        <div className="flex items-center gap-2"><User size={14} className="text-indigo-500" /> 최고 관리자</div>
                                    </div>
                                </div>

                                <div className="aspect-[1.8] w-full border border-slate-200 overflow-hidden mb-12 shadow-sm bg-slate-100">
                                    {editingPost?.thumbnail && (
                                        <img src={editingPost.thumbnail} alt="" className="w-full h-full object-cover" />
                                    )}
                                </div>

                                <div className="max-w-none text-slate-700 leading-[2.2] text-lg">
                                    {editingPost?.excerpt && (
                                        <div className="mb-12 font-black text-xl text-slate-900 leading-[1.6] border-l-8 border-indigo-600 pl-10 py-6 bg-slate-50">
                                            {editingPost.excerpt}
                                        </div>
                                    )}
                                    
                                    <div 
                                        className="blog-content prose prose-slate prose-indigo max-w-none whitespace-pre-wrap leading-relaxed"
                                        dangerouslySetInnerHTML={{ __html: formatContent(editingPost?.content || '') || '<p class="text-slate-400 italic font-bold">본문 내용을 기다리는 중...</p>' }} 
                                    />
                                </div>
                             </div>
                        </div>
                    </div>
                </div>
            )}
        </div>
    );
}

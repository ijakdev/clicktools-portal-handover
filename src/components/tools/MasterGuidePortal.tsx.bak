"use client";

import React, { useState } from 'react';
import { EXPERT_GUIDES, ExpertGuide } from '@/data/expert-guides';
import { cn } from '@/lib/utils';
import { ChevronDown, ChevronRight, Zap, Lightbulb, Flame, Info, CheckCircle2 } from 'lucide-react';
import { motion, AnimatePresence } from 'framer-motion';

interface MasterGuidePortalProps {
    toolId: string;
}

export default function MasterGuidePortal({ toolId }: MasterGuidePortalProps) {
    const guides = EXPERT_GUIDES[toolId];
    const [openId, setOpenId] = useState<string | null>(guides?.[0]?.id || null);

    if (!guides || guides.length === 0) return null;

    return (
        <div className="w-full space-y-4">
            <div className="flex items-center gap-4 mb-10 pl-2">
                <div className="w-10 h-10 bg-indigo-600 text-white rounded-2xl flex items-center justify-center shadow-lg shadow-indigo-200">
                    <Zap size={20} />
                </div>
                <h2 className="text-3xl font-[900] tracking-tight text-slate-900">사용방법</h2>
            </div>

            <div className="space-y-4">
                {guides.map((guide) => (
                    <div 
                        key={guide.id}
                        className={cn(
                            "group overflow-hidden rounded-[2.5rem] border transition-all duration-500",
                            openId === guide.id 
                                ? "bg-white border-indigo-200 shadow-2xl shadow-indigo-900/5 translate-y-[-4px]" 
                                : "bg-white/40 border-slate-100 hover:border-slate-300 shadow-sm"
                        )}
                    >
                        {/* Accordion Header */}
                        <button 
                            onClick={() => setOpenId(openId === guide.id ? null : guide.id)}
                            className="w-full p-8 flex items-center justify-between text-left"
                        >
                            <div className="flex items-center gap-4">
                                <span className="text-3xl grayscale group-hover:grayscale-0 transition-all">{guide.icon}</span>
                                <h3 className={cn(
                                    "text-xl font-black transition-colors",
                                    openId === guide.id ? "text-indigo-600" : "text-slate-800"
                                )}>
                                    {guide.title}
                                </h3>
                            </div>
                            <div className={cn(
                                "w-10 h-10 rounded-full flex items-center justify-center transition-all",
                                openId === guide.id ? "bg-indigo-600 text-white rotate-180" : "bg-slate-50 text-slate-400 group-hover:bg-slate-100"
                            )}>
                                <ChevronDown size={20} />
                            </div>
                        </button>

                        {/* Accordion Content */}
                        <AnimatePresence>
                            {openId === guide.id && (
                                <motion.div
                                    initial={{ height: 0, opacity: 0 }}
                                    animate={{ height: 'auto', opacity: 1 }}
                                    exit={{ height: 0, opacity: 0 }}
                                    transition={{ duration: 0.5, ease: [0.04, 0.62, 0.23, 0.98] }}
                                >
                                    <div className="px-10 pb-12 space-y-12">
                                        {/* 1. Intro */}
                                        <div className="p-8 bg-slate-50 rounded-[2rem] border border-slate-100/50">
                                            <h4 className="text-sm font-black text-slate-400 uppercase tracking-[0.2em] mb-4">📢 안내</h4>
                                            <p className="text-lg font-bold text-slate-700 leading-relaxed whitespace-pre-line">
                                                {guide.content.intro}
                                            </p>
                                        </div>

                                        {/* 2. Key Concepts */}
                                        {guide.content.keyConcepts && (
                                            <div>
                                                <h4 className="text-xl font-black text-slate-900 mb-6 flex items-center gap-2">
                                                    <span className="text-2xl text-amber-500">⚡</span> 핵심 개념
                                                </h4>
                                                <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                                                    {guide.content.keyConcepts.map((item, idx) => (
                                                        <div key={idx} className="p-4 bg-white border border-slate-100 rounded-2xl flex items-center gap-3 shadow-sm">
                                                            <div className="w-1.5 h-1.5 bg-amber-400 rounded-full shrink-0" />
                                                            <span className="text-slate-600 font-bold">{item}</span>
                                                        </div>
                                                    ))}
                                                </div>
                                            </div>
                                        )}

                                        {/* 3. Features & Logic */}
                                        <div className="grid grid-cols-1 md:grid-cols-2 gap-8">
                                            {guide.content.features.map((feature, idx) => (
                                                <div key={idx} className="flex flex-col gap-4">
                                                    <p className="text-lg font-black text-slate-900 flex items-center gap-3">
                                                        <span className="w-8 h-8 bg-indigo-50 text-indigo-600 rounded-lg flex items-center justify-center text-sm font-black">{idx + 1}</span>
                                                        {feature.title}
                                                    </p>
                                                    <div className="p-6 bg-slate-50/50 rounded-2xl border border-slate-100 text-slate-600 font-bold leading-relaxed whitespace-pre-line text-sm opacity-80">
                                                        {feature.desc}
                                                    </div>
                                                </div>
                                            ))}
                                        </div>

                                        {/* 4. Usage (Simple) */}
                                        {guide.content.usageSteps.length > 0 && (
                                            <div>
                                                <h4 className="text-xl font-black text-slate-900 mb-6 flex items-center gap-2">
                                                    <span className="text-2xl text-blue-500">⚡</span> 사용 방법 (아주 간단)
                                                </h4>
                                                <div className="flex flex-wrap gap-4">
                                                    {guide.content.usageSteps.map((step, idx) => (
                                                        <div key={idx} className="flex items-center gap-3 text-slate-700 bg-white px-6 py-3 rounded-full border border-slate-100 shadow-sm font-bold text-sm">
                                                            <CheckCircle2 size={16} className="text-indigo-500" />
                                                            {step}
                                                        </div>
                                                    ))}
                                                </div>
                                            </div>
                                        )}

                                        {/* 5. Situations */}
                                        {guide.content.situations.length > 0 && (
                                            <div>
                                                <h4 className="text-xl font-black text-slate-900 mb-6 flex items-center gap-2">
                                                    <span className="text-2xl text-emerald-500">💡</span> 활용 상황
                                                </h4>
                                                <div className="grid grid-cols-2 md:grid-cols-4 gap-4">
                                                    {guide.content.situations.map((sit, idx) => (
                                                        <div key={idx} className="text-center p-4 rounded-2xl bg-slate-50 flex flex-col items-center">
                                                            <div className="text-slate-700 font-black text-[13px]">{sit}</div>
                                                        </div>
                                                    ))}
                                                </div>
                                            </div>
                                        )}

                                        {/* 6. Summary */}
                                        <div className="p-8 bg-rose-50 rounded-[2rem] border border-rose-100 flex items-center gap-6">
                                            <div className="w-14 h-14 bg-white rounded-2xl shadow-lg flex items-center justify-center text-rose-500 text-3xl">🔥</div>
                                            <div>
                                                <h4 className="text-sm font-extrabold text-rose-400 uppercase tracking-widest mb-1">핵심 정리</h4>
                                                <p className="text-xl font-black text-rose-600 italic whitespace-pre-line">
                                                    {guide.content.summary}
                                                </p>
                                            </div>
                                        </div>
                                    </div>
                                </motion.div>
                            )}
                        </AnimatePresence>
                    </div>
                ))}
            </div>
        </div>
    );
}
